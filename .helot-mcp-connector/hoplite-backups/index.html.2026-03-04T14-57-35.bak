<!DOCTYPE html>
<html lang="en" class="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Gorgo of Sparta — Helots Dashboard</title>
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<script>tailwind.config = { darkMode: 'class' }</script>
<style>
  body { background: #0f1117; color: #e2e8f0; font-family: monospace; }
  .toast { animation: slideIn 0.4s ease, fadeOut 0.5s ease 4.5s forwards; }
  @keyframes slideIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
  @keyframes fadeOut { from { opacity: 1; } to { opacity: 0; pointer-events: none; } }
  pre { white-space: pre-wrap; word-break: break-all; }
  ::-webkit-scrollbar { width: 6px; } ::-webkit-scrollbar-track { background: #1e2130; } ::-webkit-scrollbar-thumb { background: #4a5568; }
</style>
</head>
<body class="min-h-screen p-3">

<!-- Header -->
<div class="border border-yellow-700 rounded p-3 mb-3 bg-gray-900">
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-3">
      <span class="text-2xl">🪖</span>
      <span class="text-yellow-400 font-bold text-lg tracking-widest">GORGO OF SPARTA</span>
      <span id="hdr-model" class="text-gray-500 text-sm"></span>
      <span id="hdr-project" class="text-gray-400 text-sm"></span>
    </div>
    <div class="text-xs text-gray-400 flex gap-4">
      <span>Local: in:<span id="tok-in" class="text-green-400">0</span>k out:<span id="tok-out" class="text-green-400">0</span>k</span>
      <span>Frontier: ~<span id="tok-frontier" class="text-blue-400">0</span>k (est.)</span>
      <span>TPS: <span id="tok-tps" class="text-yellow-400">-</span></span>
    </div>
  </div>
  <div class="flex gap-6 mt-2 text-sm">
    <span>⚔️  Victories: <span id="stat-v" class="text-green-400 font-bold">0</span></span>
    <span>🏛️  Wonders: <span id="stat-w" class="text-yellow-400 font-bold">0</span></span>
    <span>💀  Defeats: <span id="stat-d" class="text-red-400 font-bold">0</span></span>
    <span>Battles: <span id="stat-b" class="text-gray-300">0</span></span>
    <span>Streak: <span id="stat-s" class="font-bold">0</span></span>
    <span>🦅  Generals: <span id="stat-g" class="text-purple-400 font-bold">0</span></span>
  </div>
</div>

<!-- Main grid -->
<div class="grid grid-cols-2 gap-3 h-[calc(100vh-200px)]">

  <!-- Live Feed -->
  <div class="border border-gray-700 rounded bg-gray-900 flex flex-col">
    <div class="border-b border-gray-700 px-3 py-2 text-yellow-500 font-bold text-xs tracking-widest">LIVE FEED</div>
    <div class="px-3 py-1 text-xs">
      Phase: <span id="phase-name" class="text-yellow-300">idle</span>
    </div>
    <div id="task-list" class="px-3 py-1 text-xs flex-shrink-0 space-y-0.5 max-h-40 overflow-y-auto"></div>
    <div class="border-t border-gray-800 mt-1 flex-1 overflow-hidden">
      <div id="stream-panel" class="h-full overflow-y-auto p-2 text-xs text-green-300 font-mono"></div>
    </div>
  </div>

  <!-- War Record / Events -->
  <div class="border border-gray-700 rounded bg-gray-900 flex flex-col">
    <div class="border-b border-gray-700 px-3 py-2 text-yellow-500 font-bold text-xs tracking-widest">WAR RECORD</div>
    <div id="events-panel" class="flex-1 overflow-y-auto p-2 space-y-2"></div>
  </div>

  <!-- Run History -->
  <div class="border border-gray-700 rounded bg-gray-900 flex flex-col">
    <div class="border-b border-gray-700 px-3 py-2 text-yellow-500 font-bold text-xs tracking-widest">RUN HISTORY</div>
    <div id="runs-list" class="flex-1 overflow-y-auto p-2 space-y-1 text-xs"></div>
  </div>

  <!-- Actions -->
  <div class="border border-gray-700 rounded bg-gray-900 flex flex-col">
    <div class="border-b border-gray-700 px-3 py-2 text-yellow-500 font-bold text-xs tracking-widest">ACTIONS</div>
    <div class="p-3 space-y-3 text-xs">
      <div>
        <div class="text-gray-400 mb-1">▶ RUN — task summary + plan</div>
        <textarea id="run-summary" class="w-full bg-gray-800 border border-gray-600 rounded p-2 text-white text-xs resize-none h-12" placeholder="Task summary..."></textarea>
        <textarea id="run-plan" class="w-full bg-gray-800 border border-gray-600 rounded p-2 text-white text-xs resize-none h-12 mt-1" placeholder="Implementation plan (optional)..."></textarea>
        <button onclick="doRun()" class="mt-1 px-3 py-1 bg-yellow-700 hover:bg-yellow-600 rounded text-white font-bold">▶ RUN</button>
      </div>
      <div>
        <div class="text-gray-400 mb-1">🔍 SLINGER — research task</div>
        <textarea id="slinger-task" class="w-full bg-gray-800 border border-gray-600 rounded p-2 text-white text-xs resize-none h-12" placeholder="Research question..."></textarea>
        <button onclick="doSlinger()" class="mt-1 px-3 py-1 bg-blue-700 hover:bg-blue-600 rounded text-white font-bold">🔍 SLINGER</button>
      </div>
      <div>
        <div class="text-gray-400 mb-1">✏️ HOPLITE — file + instruction</div>
        <input id="hoplite-file" class="w-full bg-gray-800 border border-gray-600 rounded p-2 text-white text-xs mb-1" placeholder="File path...">
        <textarea id="hoplite-instr" class="w-full bg-gray-800 border border-gray-600 rounded p-2 text-white text-xs resize-none h-12" placeholder="Instruction..."></textarea>
        <button onclick="doHoplite()" class="mt-1 px-3 py-1 bg-purple-700 hover:bg-purple-600 rounded text-white font-bold">✏️ HOPLITE</button>
      </div>
      <div id="action-result" class="text-gray-400 mt-2 max-h-24 overflow-y-auto"></div>
    </div>
  </div>

</div>

<!-- Toast container -->
<div id="toast-container" class="fixed bottom-4 right-4 space-y-2 z-50"></div>

<!-- MD Modal -->
<div id="md-modal" class="hidden fixed inset-0 bg-black/80 z-40 flex items-center justify-center" onclick="closeModal(event)">
  <div class="bg-gray-900 border border-gray-600 rounded max-w-3xl w-full max-h-[80vh] flex flex-col mx-4">
    <div class="flex justify-between items-center px-4 py-2 border-b border-gray-700">
      <span id="modal-title" class="text-yellow-400 text-sm font-bold"></span>
      <button onclick="document.getElementById('md-modal').classList.add('hidden')" class="text-gray-400 hover:text-white">✕</button>
    </div>
    <div id="modal-content" class="flex-1 overflow-y-auto p-4 prose prose-invert prose-sm max-w-none"></div>
  </div>
</div>

<script>
const state = { tasks: {}, phase: 'idle' };

// SSE — events
const evtSrc = new EventSource('/events');
evtSrc.onmessage = e => {
  try { handleEvent(JSON.parse(e.data)); } catch {}
};

// SSE — stream
const streamSrc = new EventSource('/api/stream');
streamSrc.onmessage = e => {
  const panel = document.getElementById('stream-panel');
  panel.textContent += e.data + '\n';
  panel.scrollTop = panel.scrollHeight;
};

function handleEvent(ev) {
  const panel = document.getElementById('events-panel');
  const entry = document.createElement('div');
  entry.className = 'text-xs text-gray-300 border-b border-gray-800 pb-1';
  entry.textContent = JSON.stringify(ev);
  panel.appendChild(entry);
  panel.scrollTop = panel.scrollHeight;

  if (ev.type === 'run_start') {
    state.tasks = {};
    renderTasks();
    document.getElementById('phase-name').textContent = 'starting';
    document.getElementById('stream-panel').textContent = '';
    showToast('📯', 'NEW CAMPAIGN', 'Sparta marches to war.', 'border-yellow-600');
    document.getElementById('hdr-model').textContent = ev.model || '';
    document.getElementById('hdr-project').textContent = ev.projectRoot ? ev.projectRoot.split(/[\/\\]/).pop() : '';
  }
  if (ev.type === 'task_list') {
    state.tasks = {};
    for (const t of (ev.tasks || [])) state.tasks[t.id] = { ...t, status: 'pending' };
    renderTasks();
  }
  if (ev.type === 'task_status') {
    if (state.tasks[ev.taskId]) state.tasks[ev.taskId].status = ev.status;
    renderTasks();
  }
  if (ev.type === 'phase_change') {
    document.getElementById('phase-name').textContent = ev.name || ev.phase || '';
  }
  if (ev.type === 'verdict') {
    if (state.tasks[ev.taskId]) state.tasks[ev.taskId].verdict = ev.result;
    renderTasks();
  }
  if (ev.type === 'run_end') {
    fetchStats();
    loadRuns();
    const p = ev.passed || 0, f = ev.failed || 0;
    if (f === 0 && p > 0) showToast('⚔️', 'BATTLE WON', `The phalanx holds the line! ${p} tasks, 0 failed`, 'border-green-600');
    else if (p === 0) showToast('💀', 'BATTLE LOST', 'Sparta mourns her fallen.', 'border-red-600');
    else showToast('⚔️', 'PYRRHIC VICTORY', `Victory, but at a cost. ${p} pass, ${f} fail`, 'border-orange-600');
  }
  if (ev.spartaEvent) {
    if (ev.spartaEvent === 'WONDER_BUILT') showToast('🏛️', 'WONDER BUILT', 'With your shield or on it.', 'border-yellow-500');
    if (ev.spartaEvent === 'CITY_LOST') showToast('🏚️', 'CITY LOST', 'Athens advances on Sparta.', 'border-red-800');
    if (ev.spartaEvent === 'GREAT_GENERAL') showToast('🦅', 'GREAT GENERAL', 'A general worthy of Sparta.', 'border-purple-500');
  }
}

function renderTasks() {
  const el = document.getElementById('task-list');
  el.innerHTML = '';
  for (const t of Object.values(state.tasks)) {
    const icon = t.status === 'completed' && t.verdict === 'PASS' ? '✅'
      : t.status === 'completed' && t.verdict === 'FAIL' ? '❌'
      : t.status === 'in_progress' || t.status === 'running' ? '🔄' : '⏳';
    const div = document.createElement('div');
    div.className = 'flex gap-2';
    div.innerHTML = `<span>${icon}</span><span class="truncate text-gray-300">${t.desc || t.id}</span>`;
    el.appendChild(div);
  }
}

function showToast(icon, title, body, borderClass) {
  const c = document.getElementById('toast-container');
  const d = document.createElement('div');
  d.className = `toast bg-gray-900 border ${borderClass} rounded p-3 max-w-xs shadow-xl`;
  d.innerHTML = `<div class="font-bold text-sm">${icon} ${title}</div><div class="text-xs text-gray-300 mt-1">${body}</div>`;
  c.appendChild(d);
  setTimeout(() => d.remove(), 5200);
}

async function fetchStats() {
  try {
    const r = await fetch('/api/stats').then(r => r.json());
    document.getElementById('tok-in').textContent = Math.round((r.localTokens.in || 0) / 1000);
    document.getElementById('tok-out').textContent = Math.round((r.localTokens.out || 0) / 1000);
    document.getElementById('tok-frontier').textContent = Math.round((r.frontierEstimate || 0) / 1000);
    document.getElementById('tok-tps').textContent = r.localTokens.tps > 0 ? r.localTokens.tps.toFixed(1) : '-';
    const rec = r.record;
    document.getElementById('stat-v').textContent = rec.victories;
    document.getElementById('stat-d').textContent = rec.defeats;
    document.getElementById('stat-b').textContent = rec.totalBattles;
    document.getElementById('stat-w').textContent = rec.wondersBuilt;
    document.getElementById('stat-g').textContent = rec.greatGenerals;
    const s = document.getElementById('stat-s');
    s.textContent = (rec.currentStreak > 0 ? '+' : '') + rec.currentStreak;
    s.className = 'font-bold ' + (rec.currentStreak > 0 ? 'text-green-400' : rec.currentStreak < 0 ? 'text-red-400' : 'text-gray-400');
    if (r.currentRun) {
      document.getElementById('hdr-model').textContent = r.currentRun.model || '';
      document.getElementById('hdr-project').textContent = r.currentRun.projectRoot ? r.currentRun.projectRoot.split(/[\/\\]/).pop() : '';
    }
  } catch {}
}

async function loadRuns() {
  try {
    const runs = await fetch('/api/runs').then(r => r.json());
    const el = document.getElementById('runs-list');
    el.innerHTML = '';
    for (const run of runs.slice(0, 20)) {
      const d = document.createElement('div');
      d.className = 'flex gap-2 items-center hover:bg-gray-800 rounded p-1';
      d.innerHTML = `<span class="text-gray-400 truncate flex-1">${run.id}</span>`;
      if (run.hasReview) {
        const btn = document.createElement('button');
        btn.className = 'text-blue-400 hover:text-blue-300 flex-shrink-0';
        btn.textContent = 'review';
        btn.onclick = () => openMd(run.reviewPath, run.id + ' — review');
        d.appendChild(btn);
      }
      if (run.hasProgress) {
        const btn = document.createElement('button');
        btn.className = 'text-green-400 hover:text-green-300 flex-shrink-0';
        btn.textContent = 'progress';
        btn.onclick = () => openMd(run.progressPath, run.id + ' — progress');
        d.appendChild(btn);
      }
      el.appendChild(d);
    }
  } catch {}
}

async function openMd(filePath, title) {
  try {
    const text = await fetch('/api/file?path=' + encodeURIComponent(filePath)).then(r => r.text());
    document.getElementById('modal-title').textContent = title;
    document.getElementById('modal-content').innerHTML = marked.parse(text);
    document.getElementById('md-modal').classList.remove('hidden');
  } catch (e) {
    alert('Could not load file: ' + e.message);
  }
}

function closeModal(e) {
  if (e.target === document.getElementById('md-modal')) document.getElementById('md-modal').classList.add('hidden');
}

async function doRun() {
  const summary = document.getElementById('run-summary').value.trim();
  const plan = document.getElementById('run-plan').value.trim();
  if (!summary) return;
  document.getElementById('action-result').textContent = 'Running...';
  const r = await fetch('/api/run', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ taskSummary: summary, implementationPlan: plan }) }).then(r => r.json());
  document.getElementById('action-result').textContent = r.result || r.error || JSON.stringify(r);
}

async function doSlinger() {
  const task = document.getElementById('slinger-task').value.trim();
  if (!task) return;
  document.getElementById('action-result').textContent = 'Researching...';
  const r = await fetch('/api/slinger', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ researchTask: task }) }).then(r => r.json());
  document.getElementById('action-result').textContent = r.result || r.error || JSON.stringify(r);
}

async function doHoplite() {
  const file = document.getElementById('hoplite-file').value.trim();
  const instr = document.getElementById('hoplite-instr').value.trim();
  if (!file || !instr) return;
  document.getElementById('action-result').textContent = 'Editing...';
  const r = await fetch('/api/hoplite', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ file, instruction: instr }) }).then(r => r.json());
  document.getElementById('action-result').textContent = r.result || r.error || JSON.stringify(r);
}

// Init
fetchStats();
loadRuns();
</script>
</body>
</html>
